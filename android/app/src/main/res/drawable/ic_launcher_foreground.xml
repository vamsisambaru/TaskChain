<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground for TaskChain.
  Drawn at 108dp; the inner safe zone is 72dp (centered).
  Logo glyph sits inside that safe zone so launcher masks crop cleanly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Long stroke of the check (chain segment) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M48,66 L74,40" />

    <!-- Short stroke (mirror chain segment) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M34,52 L48,66" />

    <!-- Center link cap -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.9"
        android:pathData="M48,66 m -3 0 a 3 3 0 1 0 6 0 a 3 3 0 1 0 -6 0" />
</vector>
